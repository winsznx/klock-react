{
  "name": "@winsznx/react",
  "version": "0.1.5",
  "description": "React hooks and providers for integrating PULSE into AppKit, wagmi, and Stacks apps.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "node \"$npm_execpath\" run build && node --test test/*.test.mjs"
  },
  "keywords": [
    "pulse",
    "react",
    "wagmi",
    "stacks",
    "web3"
  ],
  "author": "PULSE Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winsznx/klock-react.git"
  },
  "homepage": "https://github.com/winsznx/klock-react#readme",
  "bugs": {
    "url": "https://github.com/winsznx/klock-react/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@winsznx/sdk": "^0.1.3"
  },
  "peerDependencies": {
    "@reown/appkit": "^1.8.15",
    "@stacks/connect": "^8.2.4",
    "@stacks/transactions": "^7.3.1",
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "viem": "^2.43.3",
    "wagmi": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "^5"
  }
}
